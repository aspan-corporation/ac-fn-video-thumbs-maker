{
  "name": "ac-fn-video-thumbs-maker",
  "version": "0.1.0",
  "bin": {
    "ac-fn-video-thumbs-maker": "bin/ac-fn-video-thumbs-maker.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "npm run build && cdk synth",
    "deploy": "npm run build && cdk deploy --require-approval never",
    "deploy:with-approval": "npm run build && cdk deploy",
    "diff": "npm run build && cdk diff",
    "destroy": "cdk destroy",
    "bootstrap": "cdk bootstrap",
    "unit": "jest",
    "lint": "eslint '*.ts' --quiet --fix",
    "compile": "tsc",
    "test": "npm run compile && npm run unit",
    "start:local": "ts-node-esm",
    "start:watch": "npx nodemon --ext 'ts' --exec ts-node-esm index.ts",
    "clean:tsc": "find . -type f \\( -name '*.js' -o -name '*.d.ts' -o -name '*.js.map' \\) ! -path './node_modules/*' ! -path './cdk.out/*' ! -name 'jest.config.js' ! -name 'eslint.config.js' -delete",
    "clean:cdk": "rm -rf cdk.out",
    "clean": "npm run clean:tsc && npm run clean:cdk"
  },
  "devDependencies": {
    "@aspan-corporation/ac-shared-cdk": "^0.1.1",
    "@aws-lambda-powertools/batch": "^2.29.0",
    "@types/aws-lambda": "^8.10.159",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "aws-cdk": "2.1100.1",
    "aws-cdk-lib": "2.232.1",
    "esbuild": "^0.17.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "dependencies": {
    "@aspan-corporation/ac-shared": "^1.2.21"
  }
}
